# Copy this file to `.env` (which is git-ignored) and fill in your values.
# Loaded automatically by scripts/ingest.py, scripts/ask.py and
# scripts/pull.py (connectors); nothing else uses it.

# ---------------------------------------------------------------------------
# LLM provider for the summarizer + topic tagger
# ---------------------------------------------------------------------------
#
# Pick ONE of: anthropic, openai, gemini, local. If BRAIN_LLM_PROVIDER is
# unset, the summarizer auto-detects from whichever API key below is
# present (anthropic > openai > gemini > local).
#
# If no provider is configured, ingestion still works but the index
# notes show placeholders for Summary, Key points, and Topics.

# BRAIN_LLM_PROVIDER=anthropic

# Optional override for the model name. Defaults per provider:
#   anthropic: claude-haiku-4-5
#   openai:    gpt-5-mini
#   gemini:    gemini-2.5-flash
#   local:     value of BRAIN_LOCAL_MODEL, or llama3.1:8b
# BRAIN_LLM_MODEL=

# Anthropic provider
ANTHROPIC_API_KEY=

# OpenAI provider
# OPENAI_API_KEY=

# Gemini provider (either name works)
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# Local provider — any OpenAI-compatible server
# (Ollama, LM Studio, llama.cpp's server, vLLM, etc.)
# BRAIN_LOCAL_URL=http://localhost:11434/v1
# BRAIN_LOCAL_MODEL=llama3.1:8b
# BRAIN_LOCAL_API_KEY=    # only needed if your local server enforces auth

# Skip summarization entirely, even when a provider is configured.
# BRAIN_SKIP_SUMMARY=1

# ---------------------------------------------------------------------------
# MinerU (full PDF extraction with figures, tables, formulas)
# ---------------------------------------------------------------------------

# Override the MinerU inference device. Defaults to mps on Apple
# Silicon, cuda if available, otherwise cpu.
# MINERU_DEVICE_MODE=mps

# Switch model source if Hugging Face is blocked. Default: huggingface.
# MINERU_MODEL_SOURCE=modelscope

# ---------------------------------------------------------------------------
# Semantic search
# ---------------------------------------------------------------------------

# Override the embedding-model device. Same options as MINERU_DEVICE_MODE.
# BRAIN_EMBED_DEVICE=mps
