# OS
.DS_Store
Thumbs.db

# Secrets — never commit
.env
.env.*
!.env.example

# Python / uv
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.python-version
.uv-cache/

# Editors
.vscode/
.idea/

# Notebooks
.ipynb_checkpoints/

# Models cached by extractors (MinerU/PaddleOCR weights)
.cache/
models/

# Logs are noisy and regenerate themselves on every run
logs/*.log
logs/*.tmp
logs/*.gz
# MCP server telemetry (per-machine, append-only; see mcp_server/audit.py)
logs/mcp-audit.jsonl
logs/mcp-access.jsonl

# Semantic search index is regenerable from archive/processed/
# (rebuilt by every ingest, or by --rebuild-search-index)
metadata/embeddings.npy
metadata/embeddings.tmp.npy
metadata/embeddings_meta.jsonl
metadata/embeddings_meta.jsonl.tmp
metadata/.embeddings.lock

# Mined eval candidates hold real search-query strings (from the access log);
# they are a scratchpad for hand-promotion into retrieval_golden.jsonl, not
# durable state, and must never be committed or synced to the public template.
scripts/eval/mined_candidates.jsonl

# Concept-relationship graph is derived from index.jsonl + embeddings
# (rebuilt by every ingest, or by --rebuild-connections)
metadata/connections.jsonl
metadata/.connections-*.jsonl

# Figure-caption cache (LLM-derived; rebuilt by --caption-figures). The
# captions also live inline in archive/processed/, which is the durable copy.
metadata/captions.jsonl
metadata/.captions-*.jsonl

# Obsidian workspace state (per-machine; keep config + plugins)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache

# Installed community plugins — per-machine, and plugin data.json files
# often contain API keys (e.g. Copilot for Obsidian). The list of enabled
# plugin IDs in .obsidian/community-plugins.json is fine to commit.
.obsidian/plugins/

# Copilot for Obsidian local state — conversations and the plugin's own
# embedding index. Per-machine, sometimes sensitive.
copilot/

# Transient ingest staging (junk html set aside, handwritten holding)
.staging_*/

# Oversized raw slides (>50MB, exceed GitHub's 100MB limit) — kept local only
/archive/raw/university/ELEC0031/NPC extra @10th Oct.pdf
/archive/raw/university/ELEC0031/NPC extra @10th Oct.pptx
/archive/raw/university/ELEC0031/NPC extra @24th Oct.pdf
/archive/raw/university/ELEC0031/NPC extra @24th Oct.pptx
/archive/raw/university/ELEC0031/NPC extra at 3rd week.pdf
/archive/raw/university/ELEC0031/NPC extra at 3rd week.pptx
/inbox/university/ELEC0031/NPC extra @10th Oct.pdf
/inbox/university/ELEC0031/NPC extra @24th Oct.pdf
/inbox/university/ELEC0031/NPC extra at 3rd week.pdf
